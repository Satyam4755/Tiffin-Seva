<%- include('../partials/head', { title: typeof title !== 'undefined' ? title : 'Developer' }) %>
<%- include('../partials/nav', {
  currentPage: typeof currentPage !== 'undefined' ? currentPage : 'developer',
  isLogedIn: typeof isLogedIn !== 'undefined' ? isLogedIn : false,
  user: typeof user !== 'undefined' ? user : null,
  hasOrders: typeof hasOrders !== 'undefined' ? hasOrders : false,
  hasVendorOrders: typeof hasVendorOrders !== 'undefined' ? hasVendorOrders : false
}) %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap');

  :root {
    --primary: #ff6a3d;
    --secondary: #ffb64c;
    --dark: #08101d;
    --page-bg: #040915;
    --surface: rgba(11, 18, 34, 0.72);
    --surface-strong: rgba(17, 27, 48, 0.88);
    --line: rgba(255, 255, 255, 0.12);
    --text: #f7f9ff;
    --muted: #9fafcf;
    --accent: #45c9ff;
    --accent-soft: #8fe8ff;
    --accent-pink: #ff4f8a;
    --shadow-xl: 0 28px 80px rgba(0, 0, 0, 0.35);
    --shadow-md: 0 16px 45px rgba(0, 0, 0, 0.22);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    overflow-x: hidden;
    font-family: 'Manrope', sans-serif;
    background:
      radial-gradient(circle at 15% 15%, rgba(69, 201, 255, 0.18), transparent 30%),
      radial-gradient(circle at 85% 20%, rgba(255, 79, 138, 0.18), transparent 28%),
      radial-gradient(circle at 50% 85%, rgba(255, 182, 76, 0.16), transparent 28%),
      linear-gradient(180deg, #050b18 0%, #071120 45%, #040915 100%);
    color: var(--text);
  }

  .developer-page {
    position: relative;
    overflow: hidden;
  }

  .developer-shell {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .dev-section,
  .dev-hero,
  .dev-cta {
    position: relative;
    scroll-margin-top: 90px;
  }

  .dev-section {
    padding: 110px 0;
  }

  .dev-section--accent {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0));
  }

  .dev-hero {
    min-height: calc(100vh - 55px);
    display: flex;
    align-items: center;
    padding: 84px 0 72px;
  }

  .dev-cta {
    padding: 0 0 100px;
  }

  .hero-glow,
  .hero-particle {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
  }

  .hero-glow {
    filter: blur(50px);
    opacity: 0.7;
  }

  .hero-glow--one {
    width: 260px;
    height: 260px;
    top: 8%;
    left: -5%;
    background: rgba(69, 201, 255, 0.22);
  }

  .hero-glow--two {
    width: 360px;
    height: 360px;
    right: -8%;
    bottom: 2%;
    background: rgba(255, 79, 138, 0.18);
  }

  .hero-particle {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.04));
    border: 1px solid rgba(255, 255, 255, 0.12);
    animation: floatParticle 8s ease-in-out infinite;
  }

  .hero-particle--1 {
    width: 16px;
    height: 16px;
    top: 18%;
    left: 18%;
    animation-delay: 0s;
  }

  .hero-particle--2 {
    width: 24px;
    height: 24px;
    top: 28%;
    right: 18%;
    animation-delay: 1s;
  }

  .hero-particle--3 {
    width: 12px;
    height: 12px;
    bottom: 22%;
    left: 12%;
    animation-delay: 2.1s;
  }

  .hero-particle--4 {
    width: 18px;
    height: 18px;
    bottom: 16%;
    right: 26%;
    animation-delay: 3.2s;
  }

  .hero-layout,
  .profile-grid,
  .project-layout,
  .links-panel {
    display: grid;
    gap: 26px;
  }

  .hero-layout {
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    align-items: center;
    gap: 46px;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 44px;
  }

  .eyebrow,
  .section-kicker,
  .journey-step {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .eyebrow::before,
  .section-kicker::before {
    content: '';
    width: 44px;
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.8));
  }

  .hero-copy h1,
  .section-heading h2,
  .cta-card h2 {
    margin: 0;
    font-family: 'Space Grotesk', sans-serif;
    letter-spacing: -0.05em;
    line-height: 0.98;
  }

  .hero-copy h1 {
    font-size: clamp(3.2rem, 8vw, 6.2rem);
    margin-top: 18px;
  }

  .section-heading h2 {
    font-size: clamp(2.2rem, 4.2vw, 4rem);
    margin-top: 16px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #ffffff 0%, var(--accent-soft) 35%, #ffc46b 68%, #ff7b5d 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .wave {
    display: inline-block;
    transform-origin: 70% 70%;
    animation: wave 2.8s ease-in-out infinite;
  }

  .typing-line {
    min-height: 2.2rem;
    margin: 18px 0 0;
    font-size: clamp(1.15rem, 2.1vw, 1.55rem);
    color: #ffdf9c;
    font-weight: 700;
  }

  .typing-cursor {
    display: inline-block;
    width: 0.7ch;
    margin-left: 2px;
    border-right: 2px solid rgba(255, 255, 255, 0.9);
    animation: blink 0.9s step-end infinite;
  }

  .hero-description,
  .section-heading p,
  .profile-story p,
  .project-core p,
  .timeline-card p,
  .skill-card p,
  .journey-content p,
  .links-copy p,
  .cta-card p {
    color: var(--muted);
    line-height: 1.8;
    font-size: 1.02rem;
  }

  .hero-description {
    max-width: 620px;
    margin: 22px 0 0;
  }

  .hero-actions,
  .links-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .hero-actions {
    margin: 30px 0 34px;
  }

  .dev-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 22px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 700;
    transition: transform 0.35s ease, box-shadow 0.35s ease, background 0.35s ease, border-color 0.35s ease;
  }

  .dev-btn:hover {
    transform: translateY(-4px);
  }

  .dev-btn--primary {
    background: linear-gradient(135deg, var(--primary), var(--accent-pink));
    color: #fff;
    box-shadow: 0 18px 35px rgba(255, 79, 138, 0.28);
  }

  .dev-btn--ghost {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    color: var(--text);
  }

  .dev-btn--secondary {
    background: rgba(69, 201, 255, 0.1);
    border-color: rgba(69, 201, 255, 0.25);
    color: #dff8ff;
  }

  .dev-btn:hover.dev-btn--ghost,
  .dev-btn:hover.dev-btn--secondary {
    box-shadow: var(--shadow-md);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    max-width: 720px;
  }

  .metric-chip,
  .glass-panel {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04));
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .metric-chip {
    padding: 18px;
    border-radius: 22px;
  }

  .metric-chip strong {
    display: block;
    margin-bottom: 4px;
    font-size: 1.1rem;
    color: #fff;
  }

  .metric-chip span {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
  }

  .hero-visual {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
  }

  .glass-panel {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
  }

  .glass-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent 42%);
    pointer-events: none;
  }

  .hero-card,
  .profile-story,
  .founder-card,
  .project-core,
  .timeline-card,
  .skill-card,
  .journey-item,
  .cta-card {
    transform-style: preserve-3d;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .hero-card:hover,
  .profile-story:hover,
  .founder-card:hover,
  .project-core:hover,
  .timeline-card:hover,
  .skill-card:hover,
  .journey-item:hover,
  .cta-card:hover {
    box-shadow: var(--shadow-xl);
  }

  .hero-card {
    width: min(100%, 430px);
    padding: 34px;
  }

  .hero-card__content {
    position: relative;
    z-index: 1;
  }

  .status-pill,
  .pill,
  .story-tag,
  .project-chip,
  .tech-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .status-pill {
    color: #89eaff;
    background: rgba(69, 201, 255, 0.12);
  }

  .hero-card h2,
  .project-core h3,
  .skill-card h3,
  .journey-content h3,
  .founder-card h3,
  .profile-story h3,
  .timeline-card h3,
  .links-copy h3 {
    margin: 18px 0 12px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.55rem;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .hero-card h2 {
    font-size: 2rem;
  }

  .profile-ring {
    width: 152px;
    height: 152px;
    margin: 0 auto 24px;
    padding: 4px;
    border-radius: 50%;
    background: conic-gradient(from 180deg, var(--accent), var(--primary), var(--accent-pink), var(--accent));
    box-shadow: 0 20px 45px rgba(69, 201, 255, 0.18);
  }

  .profile-ring img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(7, 17, 32, 0.96);
  }

  .mini-grid,
  .story-highlights,
  .project-chip-grid,
  .badge-group,
  .founder-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .mini-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 24px;
  }

  .mini-grid div {
    padding: 15px 14px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mini-grid strong,
  .project-stat strong {
    display: block;
    color: #fff;
    font-size: 1.02rem;
    margin-bottom: 4px;
  }

  .mini-grid span,
  .project-stat span {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.88rem;
  }

  .floating-note {
    position: absolute;
    z-index: 1;
    padding: 14px 18px;
    border-radius: 18px;
    background: rgba(8, 14, 28, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    font-weight: 700;
    animation: floatY 6s ease-in-out infinite;
  }

  .floating-note--one {
    top: 10%;
    left: 0;
  }

  .floating-note--two {
    top: 22%;
    right: 0;
    animation-delay: 1.1s;
  }

  .floating-note--three {
    bottom: 13%;
    left: 8%;
    animation-delay: 2.1s;
  }

  .profile-grid {
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    align-items: stretch;
  }

  .profile-story,
  .founder-card,
  .project-core,
  .skill-card,
  .journey-item,
  .cta-card {
    padding: 34px;
  }

  .profile-story h3 {
    font-size: 2rem;
  }

  .profile-story .lead-line {
    margin-top: 0;
    font-size: 1.08rem;
    color: #dce6ff;
  }

  .story-tag,
  .project-chip,
  .tech-badge {
    background: rgba(255, 255, 255, 0.06);
    color: #e7eeff;
  }

  .story-highlights {
    margin-top: 24px;
  }

  .story-blocks {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 26px;
  }

  .story-block {
    padding: 18px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .story-block strong {
    display: block;
    color: #fff;
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .story-block span {
    color: var(--muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .founder-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .founder-card .profile-ring {
    width: 188px;
    height: 188px;
    margin-bottom: 20px;
  }

  .founder-card p {
    margin-bottom: 22px;
  }

  .project-layout {
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    align-items: start;
  }

  .project-core {
    position: sticky;
    top: 92px;
    background:
      radial-gradient(circle at top right, rgba(255, 182, 76, 0.22), transparent 35%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04));
  }

  .project-core h3 {
    font-size: 2.15rem;
  }

  .project-chip-grid {
    margin: 24px 0;
  }

  .project-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .project-stat {
    padding: 18px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .project-timeline {
    position: relative;
    display: grid;
    gap: 18px;
    padding-left: 30px;
  }

  .project-timeline::before {
    content: '';
    position: absolute;
    top: 12px;
    bottom: 12px;
    left: 9px;
    width: 2px;
    background: linear-gradient(180deg, rgba(69, 201, 255, 0.95), rgba(255, 79, 138, 0.65), rgba(255, 182, 76, 0.95));
    box-shadow: 0 0 18px rgba(69, 201, 255, 0.35);
  }

  .timeline-card {
    position: relative;
    padding: 26px 28px;
  }

  .timeline-card::before {
    content: '';
    position: absolute;
    top: 28px;
    left: -29px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--primary));
    box-shadow: 0 0 22px rgba(69, 201, 255, 0.42);
  }

  .timeline-top {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .timeline-icon {
    width: 54px;
    height: 54px;
    display: grid;
    place-items: center;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-size: 1.35rem;
    flex-shrink: 0;
  }

  .timeline-card h3 {
    margin: 0;
    font-size: 1.35rem;
  }

  .timeline-card p {
    margin: 16px 0 0;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .skill-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
  }

  .skill-head span {
    font-size: 1rem;
    color: #ffd78f;
    font-weight: 800;
  }

  .skill-card p {
    margin: 0 0 20px;
  }

  .skill-meter {
    width: 100%;
    height: 10px;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: 18px;
  }

  .skill-meter span {
    display: block;
    height: 100%;
    width: 0;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--accent), var(--primary), var(--accent-pink));
    box-shadow: 0 0 18px rgba(255, 79, 138, 0.28);
    transition: width 1.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .journey-list {
    position: relative;
    display: grid;
    gap: 20px;
  }

  .journey-list::before {
    content: '';
    position: absolute;
    top: 10px;
    bottom: 10px;
    left: 58px;
    width: 2px;
    background: linear-gradient(180deg, rgba(255, 182, 76, 0.95), rgba(69, 201, 255, 0.45));
  }

  .journey-item {
    display: grid;
    grid-template-columns: 94px minmax(0, 1fr);
    gap: 22px;
    align-items: start;
  }

  .journey-step {
    position: relative;
    justify-content: center;
    min-height: 54px;
    padding-top: 16px;
    letter-spacing: 0.18em;
    color: #ffe3b0;
  }

  .journey-step::after {
    content: '';
    position: absolute;
    top: 18px;
    left: 50%;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #ffd183, var(--primary));
    box-shadow: 0 0 18px rgba(255, 182, 76, 0.4);
  }

  .journey-content h3 {
    margin-top: 0;
  }

  .journey-content p {
    margin: 0;
  }

  .links-panel {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    padding: 34px;
  }

  .links-copy h3 {
    font-size: 2rem;
  }

  .links-copy p {
    max-width: 640px;
    margin: 12px 0 0;
  }

  .cta-card {
    text-align: center;
    padding: 48px 34px;
    background:
      radial-gradient(circle at top center, rgba(69, 201, 255, 0.22), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.06));
  }

  .cta-card h2 {
    font-size: clamp(2.2rem, 5vw, 4.6rem);
    margin-top: 16px;
  }

  .cta-card p {
    max-width: 720px;
    margin: 18px auto 30px;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(32px) scale(0.985);
    transition: opacity 0.9s ease, transform 0.9s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @keyframes wave {
    0%, 60%, 100% {
      transform: rotate(0deg);
    }

    10%, 30% {
      transform: rotate(16deg);
    }

    20%, 40% {
      transform: rotate(-8deg);
    }
  }

  @keyframes floatY {
    0%, 100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-12px);
    }
  }

  @keyframes floatParticle {
    0%, 100% {
      transform: translate3d(0, 0, 0);
    }

    50% {
      transform: translate3d(0, -14px, 0);
    }
  }

  @media (max-width: 1080px) {
    .hero-layout,
    .profile-grid,
    .project-layout,
    .links-panel {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      min-height: auto;
      padding-top: 22px;
    }

    .project-core {
      position: relative;
      top: 0;
    }

    .links-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 840px) {
    .dev-section {
      padding: 88px 0;
    }

    .hero-metrics,
    .skills-grid,
    .story-blocks {
      grid-template-columns: 1fr;
    }

    .mini-grid,
    .project-stats {
      grid-template-columns: 1fr;
    }

    .journey-list::before {
      left: 30px;
    }

    .journey-item {
      grid-template-columns: 46px minmax(0, 1fr);
    }

    .journey-step {
      justify-content: flex-start;
      padding-top: 0;
      min-height: auto;
      font-size: 0;
    }

    .journey-step::after {
      left: 8px;
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .developer-shell {
      width: min(calc(100% - 1rem), 1180px);
    }

    .dev-hero {
      min-height: auto;
      padding: 72px 0 56px;
    }

    .hero-actions,
    .links-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .dev-btn {
      width: 100%;
    }

    .profile-story,
    .founder-card,
    .project-core,
    .skill-card,
    .journey-item,
    .links-panel,
    .cta-card,
    .hero-card {
      padding: 26px;
      border-radius: 26px;
    }

    .floating-note {
      position: relative;
      inset: auto;
      margin-bottom: 12px;
      display: inline-flex;
